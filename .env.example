# ─── Database (Neon PostgreSQL) ─────────────────────────────────────────────
# Get this from console.neon.tech → your project → Connection Details
# Use the *pooled* connection string for production (ends in -pooler.*)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# The canonical URL of your deployment (no trailing slash)
# Local: http://localhost:3000
# Production: https://yourdomain.com or https://yourapp.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# NEXT_PUBLIC_APP_URL kept for any client-side URL needs (optional, falls back to APP_URL)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Brevo (transactional email) ─────────────────────────────────────────────
# Get from app.brevo.com → SMTP & API → API Keys → Create a new API key
BREVO_API_KEY="xkeysib-..."

# The verified sender address configured in Brevo (Settings → Senders & IP → Senders)
# IMPORTANT: this exact email must be added and verified in Brevo before emails will send
EMAIL_FROM="noreply@studenthome.ma"

# ─── App URL (used for email verification links) ─────────────────────────────
# Set in Vercel env vars to your deployed domain. Without this, links point to localhost.
# Local:      http://localhost:3000
# Production: https://studenthome.ma  (or https://yourapp.vercel.app)
APP_URL="http://localhost:3000"

# ─── Cloudinary (media uploads) ──────────────────────────────────────────────
# Get from console.cloudinary.com → Settings → API Keys
# IMPORTANT: also create an upload preset (Settings → Upload → Add preset)
#   - Preset name: bayt-talib
#   - Signing Mode: Unsigned  ← required for the proxy route to work
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_UPLOAD_PRESET="bayt-talib"

# ─── Admin Account Seed ───────────────────────────────────────────────────────
# Run: npx tsx scripts/seed-admin.ts  (after setting the vars above)
ADMIN_EMAIL="admin@example.com"
# Never commit the real password — keep it only in your local .env
ADMIN_PASSWORD="your-admin-password-here"

# ─── Optional: Vercel (auto-set during deployment) ───────────────────────────
# VERCEL_URL is set automatically by Vercel — leave it unset locally
