# ─── Database (Neon PostgreSQL) ─────────────────────────────────────────────
# Get this from console.neon.tech → your project → Connection Details
# Use the *pooled* connection string for production (ends in -pooler.*)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# The canonical URL of your deployment (no trailing slash)
# Local: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# ─── SMTP Email (for email verification) ────────────────────────────────────
# Example using Gmail with App Passwords:
#   1. Enable 2FA on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate an App Password and paste it as SMTP_PASS
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# ─── Admin Account Seed ───────────────────────────────────────────────────────
# Run: npx tsx scripts/seed-admin.ts  (after setting the vars above)
ADMIN_EMAIL="mohamed345el@gmail.com"
# Never commit the real password — keep it only in your local .env
ADMIN_PASSWORD="your-admin-password-here"

# ─── Optional: Vercel (auto-set during deployment) ───────────────────────────
# VERCEL_URL is set automatically by Vercel — leave it unset locally
